# Prediction Platform API environment variables
# Use this as the source of truth for the Render API service.
# Do not add quotes around values in Render.

# -----------------------------------------------------------------------------
# Required on Render API service
# -----------------------------------------------------------------------------
# If you attach a Render Postgres database, Render can provide DATABASE_URL for you.
DATABASE_URL=postgresql://user:password@host:5432/prediction_platform?schema=public

# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret

# Must match your deployed frontend origin exactly.
FRONTEND_URL=https://your-frontend.onrender.com

# Get this from The Odds API dashboard.
THE_ODDS_API_KEY=replace_with_your_odds_api_key

# -----------------------------------------------------------------------------
# Optional auth and runtime tuning
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
BCRYPT_SALT_ROUNDS=12
TRUST_PROXY=1

# -----------------------------------------------------------------------------
# Token economy defaults
# -----------------------------------------------------------------------------
SIGNUP_BONUS_TOKENS=0
WEEKLY_START_TOKENS=5
DAILY_ALLOWANCE_TOKENS=1
MAX_ALLOWANCE_TOKENS=11
MIN_STAKE_AMOUNT=1
MAX_STAKE_AMOUNT=11

# -----------------------------------------------------------------------------
# Rate limiting defaults
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# The Odds API defaults
# -----------------------------------------------------------------------------
THE_ODDS_API_REGIONS=uk
THE_ODDS_API_MARKETS=h2h
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_SYNC_INTERVAL_SECONDS=300
SETTLEMENT_INTERVAL_SECONDS=300
ODDS_SYNC_LOOKAHEAD_HOURS=48
ODDS_CACHE_TTL_SECONDS=300
ODDS_SCORES_CACHE_TTL_SECONDS=120
ODDS_STALENESS_THRESHOLD_MINUTES=30
ODDS_API_MONTHLY_QUOTA=500
EVENT_IMPORT_INTERVAL_SECONDS=21600
AUTO_IMPORT_SPORTS=soccer_epl
CASHOUT_STALENESS_THRESHOLD_MS=300000
CASHOUT_ODDS_DRIFT_THRESHOLD_PERCENT=5

# -----------------------------------------------------------------------------
# Optional SMTP settings
# Leave unset if you do not need password reset emails yet.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-user@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=no-reply@your-domain.com
PASSWORD_RESET_EXPIRES_MINUTES=60

# -----------------------------------------------------------------------------
# Optional local seed values
# Not needed on Render unless you plan to run seed scripts there.
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_USER_EMAIL=user@example.com
SEED_PASSWORD=replace_with_seed_password
